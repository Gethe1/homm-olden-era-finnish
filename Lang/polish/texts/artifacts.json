{"sid":"campaign_ichor_item_name","text":"Punainen möykky"},
{"sid":"campaign_ichor_item_description","text":"Salaperäinen leijuva neste."},
{"sid":"campaign_ichor_item_narrativeDescription","text":"Onko se verta?"},
{"sid":"campaign_M3_freed_priestesses_item_name","text":"Loukkaantuneet papittaret"},
{"sid":"campaign_M3_freed_priestesses_item_description","text":"Ryhmä Temppelin papittaria, pelastettuna synkältä kohtalolta."},
{"sid":"campaign_M3_freed_priestesses_item_narrativeDescription","text":"Minkään kuolevaisen voiman ei pitäisi päättää, kenen on määrä elää — tai kuolla."},
{"sid":"campaign_M3_captured_priestesses_item_name","text":"Kahlitut papittaret"},
{"sid":"campaign_M3_captured_priestesses_item_description","text":"Ryhmä Temppelin papittaria, vangittuna nekromanttisia riittejä varten."},
{"sid":"campaign_M3_captured_priestesses_item_narrativeDescription","text":"Ohjaamalla heikot ja haavoittuneet lopulliseen rauhaan Jadamen nekromantikot palvelevat kaikkia mantereen kansoja."},
{"sid":"campaign_M9_phoenix_egg_item_name","text":"Feeniksin muna"},
{"sid":"campaign_M9_phoenix_egg_item_description","text":"Yhä lämmin kosketukselle."},
{"sid":"campaign_M9_phoenix_egg_item_narrativeDescription","text":"Vie se sinne, minne se kuuluu… tai älä."}
] }
