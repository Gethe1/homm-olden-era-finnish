{"sid":"catechism_of_primal_magic_artifact_narrativeDescription","text":"”Hksmilla, Maailman raivo, Alkukantainen silmä; toisin kuin kukaan muu oppinut, tuhansine kynsinesi ja monine päinesi...”"},
{"sid":"golden_goose_egg_artifact_name","text":"Kultainen hanhenmuna"},
{"sid":"golden_goose_egg_artifact_description","text":"Antaa satunnaisen ihmeellisen palkinnon satunnaisen päivitysmäärän jälkeen."},
{"sid":"golden_goose_egg_artifact_upgradeDescription","text":"Voidaan päivittää rajattomasti."},
{"sid":"golden_goose_egg_artifact_narrativeDescription","text":"Jos tietäisimme varmasti, miten kultaiset hanhet kuoriutuvat, eläisimme kuin kuninkaat. Mutta säännönmukaisuutta ei tunnu olevan."},
{"sid":"tactical_guide_artifact_name","text":"Taktinen opas"},
{"sid":"tactical_guide_artifact_description","text":"Vastustaja ei voi järjestää olentojaan uudelleen ennen taistelun alkua."},
{"sid":"tactical_guide_artifact_narrativeDescription","text":"22… Ra4 23. Nc3 Ra8 24. Nb5 Ra4 25. Nc3 Ra8 26. Nb5."},
{"sid":"pole_star_artifact_name","text":"Pohjantähti"},
{"sid":"pole_star_artifact_description","text":"+{1} näkösäde. +{0} Liikkumispistettä."},
{"sid":"pole_star_artifact_description_new","text":"Sankarin maailmankartan loitsut maksavat {0} manaa."},
{"sid":"pole_star_artifact_narrativeDescription","text":"Sanotaan, että tähdet ovat taivaan kyyneliä. Ja kyyneliä voi juoda."},
{"sid":"ogres_club_of_havoc_artifact_name","text":"Hiiden tuhonuija"},
{"sid":"ogres_club_of_havoc_artifact_description","text":"+{0} Hyökkäys."},
{"sid":"ogres_club_of_havoc_artifact_upgradeDescription","text":"Päivitys: +{0} lisää Hyökkäystä. Voidaan päivittää rajattomasti."},
{"sid":"ogres_club_of_havoc_artifact_narrativeDescription","text":"Sattumalta Ironsandin hiisillä on myös nuija, jolla ne kylvävät tuhoa."},
{"sid":"tarq_of_the_rampaging_ogre_artifact_name","text":"Riehuvan hiiden kilpi"},
{"sid":"tarq_of_the_rampaging_ogre_artifact_description","text":"+{0} Puolustus."},
{"sid":"tarq_of_the_rampaging_ogre_artifact_upgradeDescription","text":"Päivitys: +{0} lisää Puolustusta. Voidaan päivittää rajattomasti."},
{"sid":"tarq_of_the_rampaging_ogre_artifact_narrativeDescription","text":"...Miksi riehuva hiisi tarvitsisi kilpeä?"},
{"sid":"tunic_of_the_cyclops_king_artifact_name","text":"Kyklooppikuninkaan tunika"},
{"sid":"tunic_of_the_cyclops_king_artifact_description","text":"+{0} Loitsuvoima."},
{"sid":"tunic_of_the_cyclops_king_artifact_upgradeDescription","text":"Päivitys: +{0} lisää Loitsuvoimaa. Voidaan päivittää rajattomasti."},
{"sid":"tunic_of_the_cyclops_king_artifact_narrativeDescription","text":"Tässä on hänen toinen silmänsä."},
{"sid":"crown_of_the_supreme_magi_artifact_name","text":"Ylimagien kruunu"},
{"sid":"crown_of_the_supreme_magi_artifact_description","text":"+{0} Tieto."},
{"sid":"crown_of_the_supreme_magi_artifact_upgradeDescription","text":"Päivitys: +{0} lisää Tietoa. Voidaan päivittää rajattomasti."},
{"sid":"crown_of_the_supreme_magi_artifact_narrativeDescription","text":"Sanotaan, että se ajaa kantajansa hulluuteen ajan myötä."},
{"sid":"garotte_artifact_name","text":"Kuristusnaru"},
{"sid":"garotte_artifact_description","text":"–{0} Nopeus kaikille vihollisille."},
{"sid":"garotte_artifact_narrativeDescription","text":"Et voi tehdä paljoakaan, kun olet tukehtumassa."},
{"sid":"hourglass_of_protection_artifact_name","text":"Pelaaginen tiimalasi"},
{"sid":"hourglass_of_protection_artifact_description","text":"Kaikkien loitsujen jäähtymisaika lyhenee {0} kierroksella."},
{"sid":"hourglass_of_protection_artifact_narrativeDescription","text":"Vesi virtaa ylöspäin kelaten aikaa taaksepäin."},
{"sid":"fine_wand_artifact_name","text":"Hieno sauva"},
{"sid":"fine_wand_artifact_description","text":"+{0} taso kaikkiin loitsuihin."},
{"sid":"fine_wand_artifact_narrativeDescription","text":"Sauvoja käytetään mielen projektioiden keskittämiseen, aivan kuten kristallit keskittävät valon säteiksi."},
{"sid":"shoddy_shield_artifact_name","text":"Surkea kilpi"},
{"sid":"shoddy_shield_artifact_description","text":"+{0} Puolustus."},
{"sid":"shoddy_shield_artifact_narrativeDescription","text":"Se voi olla vain puunpalanen, mutta ainakin se on tukevaa puuta."},
{"sid":"eagle_armor_artifact_name","text":"Kotkahaarniska"},
{"sid":"eagle_armor_artifact_description","text":"+{0} Moraali ja Onni."},
{"sid":"eagle_armor_artifact_narrativeDescription","text":"Henget ja linnut liitävät yhdessä."},
{"sid":"chain_mail_artifact_name","text":"Rengashaarniska"},
{"sid":"chain_mail_artifact_description","text":"+{0} Puolustus."},
{"sid":"chain_mail_artifact_narrativeDescription","text":"Perussuoja ylävartalolle. Valmistaminen kestää aivan liian kauan sen keskinkertaiseen puolustukseen nähden."},
{"sid":"head_torch_artifact_name","text":"Otsalamppu"},
{"sid":"head_torch_artifact_description","text":"+{0} näkösäde."},
{"sid":"head_torch_artifact_narrativeDescription","text":"Yllättäen sen keksivät temppeliherrat, eivät kääpiöt. He tarvitsivat vielä enemmän opastavaa valoa."},
{"sid":"legions_step_artifact_name","text":"Legioonan jalka"},
{"sid":"legions_step_artifact_description","text":"+{0}% kaikkien olentojen kasvuun kaikissa kaupungeissasi."},
{"sid":"legions_step_artifact_narrativeDescription","text":"Jossakin jalaton patsas odottaa surullisena."},
{"sid":"seven_league_boots_artifact_name","text":"Seitsemän peninkulman saappaat"},
{"sid":"seven_league_boots_artifact_description","text":"+{0} Liikkumispistettä."},
{"sid":"seven_league_boots_artifact_narrativeDescription","text":"Vain hetki; tai ennen kuin nuo kengät vanhenivat. Ja niiden jälki venyi pitkäksi."},
{"sid":"shackles_of_war_artifact_name","text":"Sodan kahleet"},
{"sid":"shackles_of_war_artifact_description","text":"Estää antautumisen ja pakenemisen taistelussa. (Vaikuttaa sekä kantajaan että hänen vastustajaansa.)"},
{"sid":"shackles_of_war_artifact_narrativeDescription","text":"Olisi pitänyt ottaa myös Sodan suopunki ratsun pyydystämiseksi."},
{"sid":"swamp_boots_artifact_name","text":"Suosaappaat"},
{"sid":"swamp_boots_artifact_description","text":"Poistaa kaikki maaston sakot."},
{"sid":"swamp_boots_artifact_narrativeDescription","text":"Ne toimivat myös Lumisaappaina, Aavikkosaappaina, Kuolinmaasaappaina jne."},
{"sid":"warlord_boots_artifact_name","text":"Sotaherran saappaat"},
{"sid":"warlord_boots_artifact_description","text":"+{0} Aloitekyky liittolaisolennoille."},
{"sid":"warlord_boots_artifact_narrativeDescription","text":"Ei voi pysyä paikoillaan — täytyy toimia!"},
{"sid":"magic_key_ring_artifact_name","text":"Taika-avainrengas"},
{"sid":"magic_key_ring_artifact_description","text":"Kumoaa kaikki vaikutukset, jotka rajoittavat olentojen uudelleenjärjestelyä, antautumista, pakenemista sekä loitsukirjan ja sankarin kykyjen käyttöä taistelussa."},
{"sid":"magic_key_ring_artifact_narrativeDescription","text":"Voi avata Sodan kahleet."},
{"sid":"endless_bag_artifact_name","text":"Loputon pussi"},
{"sid":"endless_bag_artifact_description","text":"Tuottaa +{0} Jalokiveä, Kristallia tai Elohopeaa päivittäin. (Resurssi riippuu kantajan ryhmittymästä.)"},
{"sid":"endless_bag_artifact_narrativeDescription","text":"Seikkailijat ympäri maailmaa heittävät omaisuutensa näihin pusseihin. On jo aika, että joku alkaa onkia niitä ulos."},
{"sid":"spyglass_artifact_name","text":"Kaukoputki"},
{"sid":"spyglass_artifact_description","text":"+{0} näkösäde."},
{"sid":"spyglass_artifact_narrativeDescription","text":"Näen pienellä silmälläni jotakin, joka alkaa myrskyn silmästä."},
{"sid":"soulless_sash_artifact_name","text":"Sieluton vyö"},
{"sid":"soulless_sash_artifact_description","text":"–{0} Moraali vihollisolennoille."},
{"sid":"soulless_sash_artifact_narrativeDescription","text":"Toisin kuin kaikki muut vyöt, jotka ovat niin pahamaineisia sieluistaan."},
{"sid":"banner_of_four_winds_artifact_name","text":"Kuuden tuulen lippu"},
{"sid":"banner_of_four_winds_artifact_description","text":"+{0} Nopeus liittolaisolennoille."},
{"sid":"banner_of_four_winds_artifact_narrativeDescription","text":"Ennen oli seitsemäs tuuli, mutta se suututti Arinan. Ja sitten niitä oli kuusi."},
{"sid":"fallen_angel_wings_artifact_name","text":"Langenneen enkelin siivet"},
{"sid":"fallen_angel_wings_artifact_description","text":"Antaa jatkuvan lennon."},
{"sid":"fallen_angel_wings_artifact_narrativeDescription","text":"Kuiskitaan, että todelliset enkelit hylkäsivät Auringon temppelin. Oliko se temppeliherrojen kiihko — vai enkelien ylimielisyys?"},
{"sid":"flag_of_truce_artifact_name","text":"Aselevon lippu"},
{"sid":"flag_of_truce_artifact_description","text":"Kantaja säilyttää armeijansa aina paetessaan taistelusta."},
{"sid":"flag_of_truce_artifact_narrativeDescription","text":"Olit kuinka voimakas tahansa taistelukentällä, lopulta kaikki kiistat ratkaistaan poliittisesti."},
{"sid":"monster_head_artifact_name","text":"Hirviön pää"},
{"sid":"monster_head_artifact_description","text":"Kaikilla olennoilla on aina neutraali Moraali taistelussa."},
{"sid":"monster_head_artifact_narrativeDescription","text":"Ei voi olla kovin iloinen, kun vastustaja noin esittelee voittosaaliitaan."},
{"sid":"omencaller_artifact_name","text":"Enteenmanaaja"},
{"sid":"omencaller_artifact_description","text":"–{0} vihollisen Onneen."},
{"sid":"omencaller_artifact_narrativeDescription","text":"Pikku piru olkapäälläsi tietää huonoa onnea… vihollisellesi."},
{"sid":"sixth_finger_artifact_name","text":"Kuudes sormi"},
{"sid":"sixth_finger_artifact_description","text":"–{0} vihollisen Moraaliin ja Onneen."},
{"sid":"sixth_finger_artifact_narrativeDescription","text":"Kuningas Elloranilla sanottiin olleen kirottu kosketus. Vieläkin hänen sormensa tuo epäonnea, kunhan annat sen kasvaa käteesi."},
{"sid":"soulscaller_ring_artifact_name","text":"Sielunmanaajan sormus"},
{"sid":"soulscaller_ring_artifact_description","text":"Vihollinen menettää {0} tasoa kaikissa taikakoulun loitsuissa."},
{"sid":"soulscaller_ring_artifact_narrativeDescription","text":"Verhon takaa kutsuttuina ne auttavat mielellään tukahduttamaan vihollisesi — sillä ne tietävät, että jonain päivänä on sinun vuorosi maksaa niiden hinta."},
{"sid":"chain_link_artifact_name","text":"Ketjun lenkki"},
{"sid":"chain_link_artifact_description","text":"Kieltää kantajaa ja vihollissankaria loitsimasta tason {0} ja {1} loitsuja taistelussa."},
{"sid":"chain_link_artifact_narrativeDescription","text":"Concubus-ketjun lenkki sormessa kannettavaksi. Se on nähnyt paljon."},
{"sid":"ring_of_neutrality_artifact_name","text":"Neutraaliuden sormus"},
{"sid":"ring_of_neutrality_artifact_description","text":"Kaikilla olennoilla on aina neutraali Onni taistelussa."},
{"sid":"ring_of_neutrality_artifact_narrativeDescription","text":"Mahdollisuudet voidaan laskea — ja neutraloida."},
{"sid":"lords_ring_artifact_name","text":"Herran sormus"},
{"sid":"lords_ring_artifact_description","text":"Liittolaisolennoilla on +{0} Aloitekyky."},
{"sid":"lords_ring_artifact_narrativeDescription","text":"Kun herrasi käskee, nouset ja lähdet. Niin yksinkertaista se on."},
{"sid":"demonic_heart_artifact_name","text":"Demoninen sydän"},
{"sid":"demonic_heart_artifact_description","text":"Korvaa kaikki sankarin loitsut niiden mestarillisilla versioilla (jos sellaisia on)."},
{"sid":"demonic_heart_artifact_narrativeDescription","text":"Jokaisella on sydämessään koko maailman voima. Sinun täytyy vain virittäytyä Kuoron suhinaan löytääksesi sen."},
{"sid":"voodoosh_doll_artifact_name","text":"Voodoo-nukke"},
{"sid":"voodoosh_doll_artifact_description","text":"Kun kantaja kukistetaan, hänet voi silti palkata takaisin tavernasta."},
{"sid":"voodoosh_doll_artifact_narrativeDescription","text":"Ja millainen ihana yhteisö häntä siellä odottaakaan!"},
{"sid":"holy_sigil_of_roph_artifact_name","text":"Rophin pyhä sinetti"},
{"sid":"holy_sigil_of_roph_artifact_description","text":"Kun yllä, antaa kaikki oppimattomat seuraavien taitojen alataidot: Vanhurskaus, Manaus, Kuiskinta, Triumviraatin voima, Syvyyden yhteys, Manaa parvi."},
{"sid":"holy_sigil_of_roph_artifact_narrativeDescription","text":"Kukaan ei muista, ketä Roph aikoinaan palveli, mutta hän teki sen järkkymättömällä uskollisuudella. Aikanaan hänestä tuli paikallinen pyhimys, joka ruumiillisti horjumattoman omistautumisen ihanteet hallitsijalleen, ryhmittymälleen ja itselleen."},
{"sid":"holy_sigil_of_eridore_artifact_name","text":"Eridoren pyhä sinetti"},
{"sid":"holy_sigil_of_eridore_artifact_description","text":"Kun yllä, antaa kaikki oppimattomat seuraavien taitojen alataidot: Logistiikka, Taikataistelu, Viisaus."},
{"sid":"holy_sigil_of_eridore_artifact_narrativeDescription","text":"Eridore, keijukaisten kepposena keksimä kuvitteellinen jumaluus, päätyi myöhemmin monien palvomaksi, jotka tahtoivat siunata viestinsä."},
{"sid":"holy_sigil_of_mearea_artifact_name","text":"Mearean pyhä sinetti"},
{"sid":"holy_sigil_of_mearea_artifact_description","text":"Kun yllä, antaa kaikki oppimattomat seuraavien taitojen alataidot: Onni, Talous, Päivänvalotaikuus."},
{"sid":"holy_sigil_of_mearea_artifact_narrativeDescription","text":"Tarujen kultaisen lohikäärmeen sanotaan tuovan niin suurta vaurautta, että siitä lopulta tuli palvonnan kohde."},
{"sid":"holy_sigil_of_insara_artifact_name","text":"Insaran pyhä sinetti"},
{"sid":"holy_sigil_of_insara_artifact_description","text":"Kun yllä, antaa kaikki oppimattomat seuraavien taitojen alataidot: Johtajuus, Oivallus, Diplomatia, Taktiikka."},
{"sid":"holy_sigil_of_insara_artifact_narrativeDescription","text":"Tarina kertoo oraakkelista, joka saattoi ennustaa sotien ja taisteluiden lopputulokset. Ajan myötä kenraalit alkoivat kunnioittaa hänen nimeään."},
{"sid":"holy_sigil_of_quix_artifact_name","text":"Quixin pyhä sinetti"},
{"sid":"holy_sigil_of_quix_artifact_description","text":"Kun yllä, antaa kaikki oppimattomat seuraavien taitojen alataidot: Arkaaninen taikuus, Tiedustelu, Taistelutaito, Thaumaturgia."},
{"sid":"holy_sigil_of_quix_artifact_narrativeDescription","text":"Valloittaja, jonka sanottiin olevan kuolematon, mutta joka sen sijaan lähti valloittamaan uusia maailmoja tämän ulkopuolelta — Quix on nyt olemassa vain tarussa."},
{"sid":"holy_sigil_of_the_seven_magi_artifact_name","text":"Seitsemän magin pyhä sinetti"},
{"sid":"holy_sigil_of_the_seven_magi_artifact_description","text":"Kun yllä, antaa kaikki oppimattomat seuraavien taitojen alataidot: Noituus, Yönvarjotaikuus, Vastustus."},
{"sid":"holy_sigil_of_the_seven_magi_artifact_narrativeDescription","text":"Seitsemän mahtavaa maagia muodosti salaisen veljeskunnan. Sitä ei enää ole olemassa, mutta heidän sinettinsä kestää."},
{"sid":"holy_sigil_of_the_second_man_artifact_name","text":"Toisen ihmisen pyhä sinetti"},
{"sid":"holy_sigil_of_the_second_man_artifact_description","text":"Kun yllä, antaa kaikki oppimattomat seuraavien taitojen alataidot: Hyökkäys, Manaa avatar, Piiritystaito, Taistelu."},
{"sid":"holy_sigil_of_the_second_man_artifact_narrativeDescription","text":"Ensimmäisen ihmisen sanotaan kohdanneen kuoleman, Toisen voiman kukistamana. Ainakin niin tarut kertovat."},
{"sid":"holy_sigil_of_uurdt_artifact_name","text":"Uurdtin pyhä sinetti"},
{"sid":"holy_sigil_of_uurdt_artifact_description","text":"Kun yllä, antaa kaikki oppimattomat seuraavien taitojen alataidot: Puolustus, Alkukantainen taikuus, Värväys."},
{"sid":"holy_sigil_of_uurdt_artifact_narrativeDescription","text":"”Missä verta vuotaa, siellä kasvit kasvavat.” Tämä oli muinaisen druidikultin tunnuslause, ja vain heidän sinettinsä on jäljellä kertomaan tarinaansa."},
{"sid":"rule_of_shadow_liquid_silence_artifact_name","text":"Nestemäinen hiljaisuus"},
{"sid":"rule_of_shadow_liquid_silence_artifact_description","text":"+{0} kierrosta kaikkien vihollisolentojen kykyjen jäähtymisaikaan."},
{"sid":"rule_of_shadow_liquid_silence_artifact_upgradeDescription","text":"Päivitys: +{0} lisää kierroksia."},
{"sid":"rule_of_shadow_liquid_silence_artifact_narrativeDescription","text":"Yleinen neuvottelutyökalu Alvarin hovissa."},
{"sid":"rule_of_shadow_the_truthmaker_artifact_name","text":"Tuojantekijä"},
{"sid":"rule_of_shadow_the_truthmaker_artifact_description","text":"–{0}% Hyökkäys vihollisolennoille."},
{"sid":"rule_of_shadow_the_truthmaker_artifact_upgradeDescription","text":"Päivitys: –{0}% enemmän Hyökkäystä."},
{"sid":"rule_of_shadow_the_truthmaker_artifact_narrativeDescription","text":"Totuus on sitä, miksi sen teet. Ja jos todellisuus ei suostu, muistuta sitä, kuka täällä on vahvin."},
{"sid":"rule_of_shadow_the_truthseeker_artifact_name","text":"Totuudenetsijä"},
{"sid":"rule_of_shadow_the_truthseeker_artifact_description","text":"–{0}% Puolustus vihollisolennoille."},
{"sid":"rule_of_shadow_the_truthseeker_artifact_upgradeDescription","text":"Päivitys: –{0}% enemmän Puolustusta."},
{"sid":"rule_of_shadow_the_truthseeker_artifact_narrativeDescription","text":"Saadaksesi totuuden selville etsi ensin heidän pehmein ja haavoittuvin kohtansa."},
{"sid":"rule_of_shadow_nostrias_gaze_artifact_name","text":"Amelchian laki"},
{"sid":"rule_of_shadow_nostrias_gaze_artifact_description","text":"–{0} Aloitekyky vihollisolennoille."},
{"sid":"rule_of_shadow_nostrias_gaze_artifact_upgradeDescription","text":"Päivitys: –{0} lisää Aloitekykyä."},
{"sid":"rule_of_shadow_nostrias_gaze_artifact_narrativeDescription","text":"On uskomattoman vaikeaa tehdä jotakin, kun Alvarin kuningatar kieltää sen."},
{"sid":"ambassadors_word_diplomatic_gifts_artifact_name","text":"Diplomaattiset lahjat"},
{"sid":"ambassadors_word_diplomatic_gifts_artifact_description","text":"+{0}% suostutteluvoimaan diplomatiassa."},
{"sid":"ambassadors_word_diplomatic_gifts_artifact_upgradeDescription","text":"Päivitys: +{0}% lisää suostutteluvoimaa diplomatiassa."},
{"sid":"ambassadors_word_diplomatic_gifts_artifact_narrativeDescription","text":"Mikään itsenäisyyden halu ei kestä herkkujen voimaa."},
{"sid":"ambassadors_word_ambassadors_sash_artifact_name","text":"Suurlähettilään vyö"},
{"sid":"ambassadors_word_ambassadors_sash_artifact_description","text":"+{0}% suostutteluvoimaan diplomatiassa."},
{"sid":"ambassadors_word_ambassadors_sash_artifact_upgradeDescription","text":"Päivitys: +{0}% lisää suostutteluvoimaa diplomatiassa."},
{"sid":"ambassadors_word_ambassadors_sash_artifact_narrativeDescription","text":"He seuraavat sinua, jos näytät kauniilta!"},
{"sid":"excalibur_artifact_name","text":"Excalibur"},
{"sid":"excalibur_artifact_description","text":"Sankarillinen isku tappaa +{0} yksikköä. Toimii tason {1} olentoihin asti."},
{"sid":"excalibur_artifact_upgradeDescription","text":"Päivitys: +{0} lisää yksikköä."},
{"sid":"excalibur_artifact_narrativeDescription","text":"Mikään suomu, haarniska tai kilpi ei tarjoa suojaa tätä terää vastaan."},
{"sid":"caduceus_artifact_name","text":"Caduceus"},
{"sid":"caduceus_artifact_description","text":"Sankarillinen isku palauttaa {0} manaa."},
{"sid":"caduceus_artifact_upgradeDescription","text":"Päivitys: +{0} lisää manaa."},
{"sid":"caduceus_artifact_narrativeDescription","text":"Tällä veri voi muuttua taiaksi ja aine voi muuttua hengeksi."},
{"sid":"two_faced_mask_artifact_name","text":"Kaksinaamainen naamio"},
{"sid":"two_faced_mask_artifact_description","text":"Sankari voi käyttää loitsukirjaa {0} ylimääräistä kertaa taistelukierroksen aikana."},
{"sid":"two_faced_mask_artifact_narrativeDescription","text":"Kaiverrus kuuluu: <i>”Jaa kasvosi, niin et koskaan kohtaa taistelua yksin.”</i>"},
{"sid":"seal_of_silence_artifact_name","text":"Hiljaisuuden sinetti"},
{"sid":"seal_of_silence_artifact_description","text":"+{0} kierrosta kaikkien vihollisloitsujen jäähtymisaikaan."},
{"sid":"seal_of_silence_artifact_narrativeDescription","text":"Se tekee enemmän kuin estää puheen; se imee itse halun vastustaa."},
{"sid":"ancient_idol_artifact_name","text":"Muinainen epäjumala"},
{"sid":"ancient_idol_artifact_description","text":"Sankari ohittaa rajoituksen käyttää samaa taikakoulua kahdesti."},
{"sid":"ancient_idol_artifact_narrativeDescription","text":"Voima virtaa epäjumalan kivisilmistä ja virtaa sen omistajan ruumiiseen."},
{"sid":"orb_of_destruction_artifact_name","text":"Tuhon pallo"},
{"sid":"orb_of_destruction_artifact_description","text":"Sankari tekee +{0}% Taikavahinkoa."},
{"sid":"orb_of_destruction_artifact_alt_description","text":"Sankarillinen isku tekee +{0} perusvahinkoa."},
{"sid":"orb_of_destruction_artifact_narrativeDescription","text":"Se ottaa kaiken sen, mitä olet, ja muuttaa sen raa'aksi voimaksi."},
{"sid":"warriors_strength_warriors_belt_artifact_name","text":"Soturin vyö"},
{"sid":"warriors_strength_warriors_belt_artifact_description","text":"+{0} Hyökkäys."},
{"sid":"warriors_strength_warriors_belt_artifact_upgradeDescription","text":"Päivitys: +{0} lisää Hyökkäystä."},
{"sid":"warriors_strength_warriors_belt_artifact_narrativeDescription","text":"Jokainen soturi osaa arvostaa hyvää vyötä, johon ripustaa miekkansa."},
{"sid":"warriors_strength_warriors_oberegus_artifact_name","text":"Soturin amuletti"},
{"sid":"warriors_strength_warriors_oberegus_artifact_description","text":"+{0} Hyökkäys."},
{"sid":"warriors_strength_warriors_oberegus_artifact_upgradeDescription","text":"Päivitys: +{0} lisää Hyökkäystä."},
